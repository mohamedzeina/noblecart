<button class="admin-mobile-toggle" id="admin-sidebar-toggle" aria-label="Open admin menu" aria-expanded="false">
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="22" height="22">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
  </svg>
</button>
<div class="admin-backdrop" id="admin-sidebar-backdrop" aria-hidden="true"></div>

<aside class="admin-sidebar" id="admin-sidebar">
  <a href="/admin/dashboard" class="admin-sidebar__brand">
    <span class="admin-sidebar__mark" aria-hidden="true">◆</span>
    <span class="admin-sidebar__wordmark">Noble<span class="admin-sidebar__italic">cart</span></span>
    <span class="admin-sidebar__pill">Admin</span>
  </a>

  <nav class="admin-sidebar__nav" aria-label="Admin sections">
    <span class="admin-sidebar__group-label">— Manage</span>
    <a href="/admin/dashboard" class="admin-sidebar__nav-item<%= path === '/admin/dashboard' ? ' admin-sidebar__nav-item--active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12 11.204 3.045c.439-.44 1.152-.44 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
      </svg>
      Dashboard
    </a>
    <a href="/admin/products" class="admin-sidebar__nav-item<%= path.startsWith('/admin/products') || path.startsWith('/admin/edit-product') || path.startsWith('/admin/add-product') || path.startsWith('/admin/product/') ? ' admin-sidebar__nav-item--active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/>
      </svg>
      Products
    </a>
    <a href="/admin/orders" class="admin-sidebar__nav-item<%= path === '/admin/orders' ? ' admin-sidebar__nav-item--active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z"/>
      </svg>
      Orders
    </a>

    <span class="admin-sidebar__group-label">— Quick action</span>
    <a href="/admin/add-product" class="admin-sidebar__nav-item admin-sidebar__nav-item--accent<%= path === '/admin/add-product' ? ' admin-sidebar__nav-item--active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      Add product
    </a>
  </nav>

  <div class="admin-sidebar__footer">
    <a href="/" class="admin-sidebar__visit">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="14" height="14">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
      </svg>
      View storefront
    </a>
    <form action="/admin/logout" method="post" class="admin-sidebar__logout-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="admin-sidebar__logout">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="14" height="14">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
        </svg>
        Sign out
      </button>
    </form>
  </div>
</aside>
