<% if (isAuthenticated) { %>
<div class="cart-drawer" id="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__overlay" id="cart-drawer-overlay"></div>
  <aside class="cart-drawer__panel" role="dialog" aria-label="Shopping Cart">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart <span class="cart-drawer__count" id="drawer-count"></span></h2>
      <button class="cart-drawer__close" id="cart-drawer-close" aria-label="Close cart">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="cart-drawer__body" id="cart-drawer-body">
      <div class="cart-drawer__loading">Loading…</div>
    </div>
    <div class="cart-drawer__footer" id="cart-drawer-footer">
      <div class="cart-drawer__total-row">
        <span>Total</span>
        <span id="drawer-grand-total">$0.00</span>
      </div>
      <a href="/checkout" class="btn btn--solid cart-drawer__checkout">Proceed to Checkout</a>
      <button class="cart-drawer__continue" id="cart-drawer-continue">Continue Shopping</button>
    </div>
  </aside>
</div>
<input type="hidden" id="cart-drawer-csrf" value="<%= csrfToken %>">
<% } %>
