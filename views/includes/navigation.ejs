<a href="#products" class="skip-link">Skip to main content</a>
<div class="backdrop"></div>
<header class="main-header">
  <button id="side-menu-toggle">Menu</button>
  <a class="main-header__brand" href="/">Noblecart_</a>
  <nav class="main-header__nav">
    <ul class="main-header__item-list">
      <li class="main-header__item">
        <a class="nav-cat <%= path === '/category/electronics' ? 'active' : '' %>" href="/category/electronics">Electronics</a>
      </li>
      <li class="main-header__item">
        <a class="nav-cat <%= path === '/category/fashion' ? 'active' : '' %>" href="/category/fashion">Fashion</a>
      </li>
      <li class="main-header__item">
        <a class="nav-cat <%= path === '/category/home' ? 'active' : '' %>" href="/category/home">Home & Living</a>
      </li>
      <li class="main-header__item">
        <a class="nav-cat <%= path === '/category/accessories' ? 'active' : '' %>" href="/category/accessories">Accessories</a>
      </li>
    </ul>
    <ul class="main-header__item-list">
      <% if (!isAuthenticated) { %>
      <li class="main-header__item">
        <a class="<%= path === '/login' ? 'active' : '' %>" href="/login">Login</a>
      </li>
      <li class="main-header__item">
        <a class="<%= path === '/signup' ? 'active' : '' %>" href="/signup">Signup</a>
      </li>
      <% } else { %>
      <li class="main-header__item">
        <a class="<%= path === '/orders' ? 'active' : '' %>" href="/orders">Orders</a>
      </li>
      <li class="main-header__item">
        <a class="nav-icon <%= path === '/cart' ? 'active' : '' %>" href="/cart" title="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="22" height="22">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
          </svg>
          <% if (cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
          <% } %>
        </a>
      </li>
      <li class="main-header__item">
        <a class="nav-admin-link <%= path.startsWith('/admin') ? 'active' : '' %>" href="/admin/products">Admin</a>
      </li>
      <li class="main-header__item">
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit">Logout</button>
        </form>
      </li>
      <% } %>
    </ul>
  </nav>
</header>

<nav class="mobile-nav">
  <ul class="mobile-nav__item-list">
    <li class="mobile-nav__item">
      <a class="<%= path === '/category/electronics' ? 'active' : '' %>" href="/category/electronics">Electronics</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/category/fashion' ? 'active' : '' %>" href="/category/fashion">Fashion</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/category/home' ? 'active' : '' %>" href="/category/home">Home & Living</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/category/accessories' ? 'active' : '' %>" href="/category/accessories">Accessories</a>
    </li>
    <li class="mobile-nav__sep"></li>
    <% if (isAuthenticated) { %>
    <li class="mobile-nav__item">
      <a class="<%= path === '/cart' ? 'active' : '' %>" href="/cart">Cart</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/orders' ? 'active' : '' %>" href="/orders">Orders</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/admin/products' ? 'active' : '' %>" href="/admin/products">Admin</a>
    </li>
    <li class="mobile-nav__item">
      <form action="/logout" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit">Logout</button>
      </form>
    </li>
    <% } else { %>
    <li class="mobile-nav__item">
      <a class="<%= path === '/login' ? 'active' : '' %>" href="/login">Login</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/signup' ? 'active' : '' %>" href="/signup">Signup</a>
    </li>
    <% } %>
  </ul>
</nav>
