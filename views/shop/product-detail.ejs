<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/product.css">
</head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% const catLabels = { electronics: 'Electronics', fashion: 'Fashion', home: 'Home & Living', wearables: 'Wearables & Gadgets' }; %>
            <nav class="breadcrumb product-detail__breadcrumb" aria-label="Breadcrumb">
                <a href="/" class="breadcrumb__item">All Products</a>
                <span class="breadcrumb__sep">/</span>
                <a href="/category/<%= product.category %>" class="breadcrumb__item"><%= catLabels[product.category] || product.category %></a>
                <span class="breadcrumb__sep">/</span>
                <span class="breadcrumb__item breadcrumb__item--current"><%= product.title %></span>
            </nav>
            <div class="product-detail">
                <div class="product-detail__image">
                    <% if (product.modelUrl) { %>
                        <div class="view-toggle">
                            <button class="view-toggle__btn active" data-view="image">Photo</button>
                            <button class="view-toggle__btn" data-view="3d">3D View</button>
                        </div>
                    <% } %>
                    <div id="view-image">
                        <img src="<%= product.imageUrl %>" alt="<%= product.title %>">
                    </div>
                    <% if (product.modelUrl) { %>
                        <div id="view-3d" data-model-url="<%= product.modelUrl %>"></div>
                    <% } %>
                </div>
                <div class="product-detail__info">
                    <span class="product-detail__badge"><%= catLabels[product.category] || product.category %></span>
                    <h1 class="product-detail__title"><%= product.title %></h1>
                    <% if (avgRating) { %>
                    <a href="#reviews" class="product-detail__rating">
                        <span class="stars-display"><%- stars(avgRating) %></span>
                        <span class="product-detail__rating-avg"><%= avgRating.toFixed(1) %></span>
                        <span class="product-detail__rating-count">(<%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %>)</span>
                    </a>
                    <% } %>
                    <p class="product-detail__price">$<%= product.price.toFixed(2) %></p>
                    <% if (product.stock === 0) { %>
                        <p class="stock-badge stock-badge--out">Out of Stock</p>
                    <% } else if (product.stock <= 5) { %>
                        <p class="stock-badge stock-badge--low">Only <%= product.stock %> left in stock</p>
                    <% } %>
                    <p class="product-detail__description"><%= product.description %></p>

                    <% if (isAuthenticated) { %>
                        <%- include('../includes/add-to-cart.ejs', {product: product}) %>
                        <button
                          class="wishlist-btn wishlist-detail-btn<%= wishlistIds.includes(product._id.toString()) ? ' wishlist-btn--active' : '' %>"
                          data-product-id="<%= product._id %>"
                          data-csrf="<%= csrfToken %>"
                          aria-label="<%= wishlistIds.includes(product._id.toString()) ? 'Remove from wishlist' : 'Save to wishlist' %>"
                        >
                          <svg class="wishlist-btn__heart wishlist-btn__heart--filled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
                          </svg>
                          <svg class="wishlist-btn__heart wishlist-btn__heart--outline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="16" height="16">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                          </svg>
                          <span class="wishlist-detail-btn__label"><%= wishlistIds.includes(product._id.toString()) ? 'Saved to Wishlist' : 'Save to Wishlist' %></span>
                        </button>
                    <% } else { %>
                        <a href="/login" class="btn product-detail__login-cta">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                            Sign in to add to cart
                        </a>
                    <% } %>

                    <div class="product-detail__trust">
                        <div class="trust-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                            </svg>
                            <span>Free shipping</span>
                        </div>
                        <div class="trust-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3" />
                            </svg>
                            <span>30-day returns</span>
                        </div>
                        <div class="trust-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                            </svg>
                            <span>Secure payment</span>
                        </div>
                    </div>
                </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" class="svg-defs" aria-hidden="true">
                <defs>
                    <linearGradient id="hsg" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="50%" stop-color="#f59e0b"/>
                        <stop offset="50%" stop-color="#e2e8f0"/>
                    </linearGradient>
                </defs>
            </svg>
            <%
                function stars(rating) {
                    const full = rating % 1 >= 0.75 ? Math.ceil(rating) : Math.floor(rating);
                    const half = rating % 1 >= 0.25 && rating % 1 < 0.75;
                    let s = '';
                    for (let i = 1; i <= 5; i++) {
                        const cls = i <= full ? ' star--filled' : (i === full + 1 && half ? ' star--half' : '');
                        s += `<svg class="star${cls}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`;
                    }
                    return s;
                }
            %>
            <% if (relatedProducts && relatedProducts.length > 0) { %>
            <section class="related-products">
                <h2 class="related-products__title">You might also like</h2>
                <div class="related-products__grid">
                    <% for (const rp of relatedProducts) { %>
                    <article class="card product-item">
                        <div class="card__image">
                            <img src="<%= rp.imageUrl %>" alt="<%= rp.title %>" loading="lazy">
                            <%- include('../includes/wishlist-btn.ejs', { product: rp }) %>
                        </div>
                        <div class="card__static">
                            <% const rpr = relatedRatingsMap && relatedRatingsMap[rp._id.toString()]; %>
                            <% if (rpr) { %>
                            <% const rpFull = rpr.avg % 1 >= 0.75 ? Math.ceil(rpr.avg) : Math.floor(rpr.avg); %>
                            <% const rpHalf = rpr.avg % 1 >= 0.25 && rpr.avg % 1 < 0.75; %>
                            <div class="card__rating">
                                <div class="card__rating-stars">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <svg class="star<%= i <= rpFull ? ' star--filled' : (i === rpFull + 1 && rpHalf ? ' star--half' : '') %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    <% } %>
                                </div>
                                <span class="card__rating-count"><%= rpr.avg.toFixed(1) %> (<%= rpr.count %>)</span>
                            </div>
                            <% } %>
                            <h3 class="product__title"><%= rp.title %></h3>
                            <p class="product__price">$<%= rp.price %></p>
                        </div>
                        <div class="card__reveal">
                            <p class="card__reveal-label">Product Details</p>
                            <p class="card__reveal-desc"><%= rp.description %></p>
                            <div class="card__actions">
                                <% if (isAuthenticated) { %>
                                    <%- include('../includes/add-to-cart.ejs', { product: rp }) %>
                                <% } %>
                                <a href="/products/<%= rp._id %>" class="btn card__details-btn">Details</a>
                            </div>
                        </div>
                    </article>
                    <% } %>
                </div>
            </section>
            <% } %>
            <section class="reviews-section" id="reviews">
                <!-- Left: summary + breakdown -->
                <div class="reviews-section__left">
                    <div class="reviews-section__header">
                        <h2 class="reviews-section__title">Reviews</h2>
                    </div>
                    <% if (avgRating) { %>
                    <div class="reviews-section__summary">
                        <div class="stars-display"><%- stars(avgRating) %></div>
                        <span class="reviews-section__avg"><%= avgRating.toFixed(1) %></span>
                        <span class="reviews-section__count">(<%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %>)</span>
                    </div>
                    <% } %>
                    <% if (reviews.length > 0) { %>
                    <div class="rating-breakdown">
                        <% ratingBreakdown.forEach(({ star, count }) => { %>
                        <div class="rating-breakdown__row">
                            <span class="rating-breakdown__label"><%= star %>★</span>
                            <div class="rating-breakdown__bar-wrap"><svg class="rating-breakdown__bar" viewBox="0 0 100 10" preserveAspectRatio="none" aria-hidden="true"><rect x="0" y="0" width="100" height="10" fill="#e2e8f0"/><rect x="0" y="0" width="<%= reviews.length ? Math.round(count / reviews.length * 100) : 0 %>" height="10" fill="#f59e0b"/></svg></div>
                            <span class="rating-breakdown__count"><%= count %></span>
                        </div>
                        <% }) %>
                    </div>
                    <% } else { %>
                    <div class="reviews-section__no-reviews">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.499Z" />
                        </svg>
                        <p class="reviews-section__no-reviews-title">No reviews yet</p>
                        <p class="reviews-section__no-reviews-sub">Be the first to share your experience with this product.</p>
                    </div>
                    <% } %>
                </div>

                <!-- Right: form + reviews -->
                <div class="reviews-section__right">
                    <% if (isAuthenticated) { %>
                    <% if (!userReview) { %>
                    <% if (!reviews.length) { %>
                    <p class="reviews-section__form-lead">Have this product? Your review helps other shoppers.</p>
                    <% } %>
                    <form class="review-form" action="/products/<%= product._id %>/review" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <p class="review-form__label">Your Rating</p>
                        <div class="star-picker" role="group" aria-label="Rating">
                            <% for (let i = 5; i >= 1; i--) { %>
                            <input type="radio" name="rating" id="star<%= i %>" value="<%= i %>" class="star-picker__input">
                            <label for="star<%= i %>" class="star-picker__label" aria-label="<%= i %> star<%= i !== 1 ? 's' : '' %>">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                            </label>
                            <% } %>
                        </div>
                        <textarea class="review-form__textarea" name="comment" rows="3" maxlength="1000" placeholder="Share your thoughts on this product…" required></textarea>
                        <p class="review-form__error<%= reviewError ? '' : ' hidden' %>" id="review-error-msg"><%= reviewError || '' %></p>
                        <button class="btn btn--solid review-form__submit" type="submit">Submit Review</button>
                    </form>
                    <% } else { %>
                    <div class="review-form review-form--existing">
                        <div class="review-form__view">
                            <div class="review-item__header">
                                <div class="review-item__avatar"><%= userReview.userName.charAt(0).toUpperCase() %></div>
                                <div class="review-item__meta">
                                    <div class="stars-display"><%- stars(userReview.rating) %></div>
                                    <div class="review-item__author-row">
                                        <span class="review-item__author"><%= userReview.userName %></span>
                                        <span class="review-form__your-badge">Your review</span>
                                        <% if (userReview.verifiedPurchase) { %><span class="review-item__verified">Verified Purchase</span><% } %>
                                    </div>
                                </div>
                                <span class="review-item__date"><%= new Date(userReview.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                            <p class="review-item__comment">"<%= userReview.comment %>"</p>
                            <div class="review-form__actions">
                                <button class="btn btn--solid review-form__edit-btn" type="button">Edit</button>
                                <form action="/products/<%= product._id %>/review/delete" method="POST" class="review-form__delete-form">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="btn review-form__delete-btn" type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                        <form class="review-form__edit-fields" action="/products/<%= product._id %>/review/update" method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <p class="review-form__label">Your Rating</p>
                            <div class="star-picker" role="group" aria-label="Rating">
                                <% for (let i = 5; i >= 1; i--) { %>
                                <input type="radio" name="rating" id="edit-star<%= i %>" value="<%= i %>" class="star-picker__input" <%= i === userReview.rating ? 'checked' : '' %>>
                                <label for="edit-star<%= i %>" class="star-picker__label">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                </label>
                                <% } %>
                            </div>
                            <textarea class="review-form__textarea" name="comment" rows="3" maxlength="1000" required><%= userReview.comment %></textarea>
                            <div class="review-form__actions">
                                <button class="btn btn--solid review-form__submit" type="submit">Save</button>
                                <button class="btn review-form__cancel-btn" type="button">Cancel</button>
                            </div>
                        </form>
                    </div>
                    <% } %>
                    <% } %>

                    <% if (reviewsListTotal > 0) { %>
                    <div class="review-sort">
                        <% [
                            { value: 'newest',  label: 'Newest' },
                            { value: 'highest', label: 'Highest Rated' },
                            { value: 'lowest',  label: 'Lowest Rated' },
                        ].forEach(chip => { %>
                        <a href="?reviewSort=<%= chip.value %>#reviews"
                           class="review-sort-chip<%= activeReviewSort === chip.value ? ' review-sort-chip--active' : '' %>">
                            <%= chip.label %>
                        </a>
                        <% }) %>
                    </div>
                    <ul class="review-list" id="review-list">
                        <% displayedReviews.forEach(review => { %>
                        <li class="review-item">
                            <div class="review-item__header">
                                <div class="review-item__avatar"><%= review.userName.charAt(0).toUpperCase() %></div>
                                <div class="review-item__meta">
                                    <div class="stars-display"><%- stars(review.rating) %></div>
                                    <div class="review-item__author-row">
                                        <span class="review-item__author"><%= review.userName %></span>
                                        <% if (review.verifiedPurchase) { %>
                                        <span class="review-item__verified">Verified Purchase</span>
                                        <% } %>
                                    </div>
                                </div>
                                <span class="review-item__date"><%= new Date(review.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                            <p class="review-item__comment">"<%= review.comment %>"</p>
                        </li>
                        <% }) %>
                    </ul>
                    <% if (reviewsListTotal > 5) { %>
                    <div class="reviews-load-more">
                        <button class="btn btn--solid reviews-load-more__btn"
                                data-product-id="<%= product._id %>"
                                data-skip="<%= displayedReviews.length %>"
                                data-review-sort="<%= activeReviewSort %>">
                            Load more reviews
                        </button>
                        <span class="reviews-load-more__count"><%= displayedReviews.length %> of <%= reviewsListTotal %></span>
                    </div>
                    <% } %>
                    <% } else if (!isAuthenticated) { %>
                    <div class="reviews-section__signin-cta">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
                        </svg>
                        <p class="reviews-section__signin-cta-text">Sign in to be the first to review this product.</p>
                    </div>
                    <% } %>
                </div>
            </section>
        </main>
        <% if (product.modelUrl) { %>
        <script type="module" src="/js/product-detail.js"></script>
        <% } %>
<%- include('../includes/end.ejs') %>
