<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/product.css">
    <link rel="stylesheet" href="/css/wishlist.css">
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" class="svg-defs" aria-hidden="true">
        <defs>
            <linearGradient id="hsg" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="50%" stop-color="#f59e0b"/>
                <stop offset="50%" stop-color="#e2e8f0"/>
            </linearGradient>
        </defs>
    </svg>

    <main id="products">
        <div class="wishlist-header">
            <span class="wishlist-header__eyebrow">— Saved for later</span>
            <h1 class="wishlist-header__title">Your <em>wishlist</em></h1>
            <% if (products.length > 0) { %>
            <p class="wishlist-header__count"><%= products.length %> saved item<%= products.length !== 1 ? 's' : '' %></p>
            <% } %>
        </div>

        <% if (products.length > 0) { %>
            <div class="grid">
                <% for (let product of products) { %>
                    <article class="card product-item" aria-label="<%= product.title %>">
                        <div class="card__image">
                            <img src="<%= product.imageUrl %>" alt="<%= product.title %>" loading="lazy">
                            <%- include('../includes/wishlist-btn.ejs', { product: product }) %>
                        </div>
                        <div class="card__static">
                            <% const r = ratingsMap && ratingsMap[product._id.toString()]; %>
                            <% if (r) { %>
                            <% const rFull = r.avg % 1 >= 0.75 ? Math.ceil(r.avg) : Math.floor(r.avg); %>
                            <% const rHalf = r.avg % 1 >= 0.25 && r.avg % 1 < 0.75; %>
                            <div class="card__rating">
                                <div class="card__rating-stars">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <svg class="star<%= i <= rFull ? ' star--filled' : (i === rFull + 1 && rHalf ? ' star--half' : '') %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    <% } %>
                                </div>
                                <span class="card__rating-count"><%= r.avg.toFixed(1) %> (<%= r.count %> review<%= r.count !== 1 ? 's' : '' %>)</span>
                            </div>
                            <% } %>
                            <h3 class="product__title"><%= product.title %></h3>
                            <p class="product__price">$<%= product.price %></p>
                        </div>
                        <div class="card__reveal">
                            <p class="card__reveal-label">Product Details</p>
                            <p class="card__reveal-desc"><%= product.description %></p>
                            <div class="card__actions">
                                <%- include('../includes/add-to-cart.ejs', {product: product}) %>
                                <a href="/products/<%= product._id %>" class="btn card__details-btn">Details</a>
                            </div>
                        </div>
                    </article>
                <% } %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="40" height="40">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                    </svg>
                </div>
                <h2 class="empty-state__title">Your wishlist is empty</h2>
                <p class="empty-state__subtitle">Save products you love and come back to them anytime.</p>
                <a href="/" class="btn empty-state__cta">Browse products</a>
            </div>
        <% } %>
    </main>
<%- include('../includes/end.ejs') %>
