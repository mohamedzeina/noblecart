<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if (products.length > 0) { %>
                <div class="cart-layout">
                    <section class="cart-items">
                        <h1 class="cart__title">Shopping Cart</h1>
                        <ul class="cart__item-list">
                            <% products.forEach(p => { %>
                                <li class="cart__item" data-product-id="<%= p.productId._id %>" data-price="<%= p.productId.price %>">
                                    <div class="cart__item-image">
                                        <img src="<%= p.productId.imageUrl %>" alt="<%= p.productId.title %>">
                                    </div>
                                    <div class="cart__item-info">
                                        <h2 class="cart__item-title"><%= p.productId.title %></h2>
                                        <p class="cart__item-price">$<%= p.productId.price.toFixed(2) %> each</p>
                                        <div class="cart__qty-controls">
                                            <button class="cart__qty-btn" data-action="decrease" data-product-id="<%= p.productId._id %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                                                </svg>
                                            </button>
                                            <span class="cart__qty-value"><%= p.quantity %></span>
                                            <button class="cart__qty-btn" data-action="increase" data-product-id="<%= p.productId._id %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="cart__item-right">
                                        <p class="cart__item-total">$<%= (p.productId.price * p.quantity).toFixed(2) %></p>
                                        <form action="/cart-delete-item" method="POST">
                                            <input type="hidden" value="<%= p.productId._id %>" name="productId">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                            <button class="cart__delete-btn" type="submit" title="Remove item">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            <% }) %>
                        </ul>
                    </section>
                    <aside class="cart-summary">
                        <h2 class="cart-summary__title">Order Summary</h2>
                        <ul class="cart-summary__items">
                            <% let total = 0; %>
                            <% products.forEach(p => { total += p.productId.price * p.quantity; %>
                                <li class="cart-summary__item" data-product-id="<%= p.productId._id %>">
                                    <span><%= p.productId.title %> &times; <span class="summary-item__qty"><%= p.quantity %></span></span>
                                    <span class="summary-item__total">$<%= (p.productId.price * p.quantity).toFixed(2) %></span>
                                </li>
                            <% }) %>
                        </ul>
                        <div class="cart-summary__total">
                            <span>Total</span>
                            <span id="cart-grand-total">$<%= total.toFixed(2) %></span>
                        </div>
                        <a href="/checkout" class="btn btn--solid cart-summary__checkout">Proceed to Checkout</a>
                    </aside>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="48" height="48">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                        </svg>
                    </div>
                    <h2 class="empty-state__title">Your cart is empty</h2>
                    <p class="empty-state__subtitle">Looks like you haven't added anything yet.</p>
                    <a href="/" class="btn">Start Shopping</a>
                </div>
            <% } %>
        </main>
        <script src="/js/cart.js"></script>
        <%- include('../includes/end.ejs') %>
