<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/orders.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if (orders.length <= 0 && statusFilter === 'all') { %>
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="48" height="48">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                        </svg>
                    </div>
                    <h2 class="empty-state__title">No orders yet</h2>
                    <p class="empty-state__subtitle">Your completed orders will appear here.</p>
                    <a href="/" class="btn btn--solid">Start Shopping</a>
                </div>
            <% } else { %>
                <div class="orders-header">
                    <h1 class="orders-header__title">Your Orders</h1>
                    <div class="orders-filter">
                        <a href="/orders?status=all"       class="orders-filter__btn<%= statusFilter === 'all'       ? ' orders-filter__btn--active' : '' %>">All</a>
                        <a href="/orders?status=active"    class="orders-filter__btn<%= statusFilter === 'active'    ? ' orders-filter__btn--active' : '' %>">Active</a>
                        <a href="/orders?status=delivered" class="orders-filter__btn<%= statusFilter === 'delivered' ? ' orders-filter__btn--active' : '' %>">Delivered</a>
                        <a href="/orders?status=canceled"  class="orders-filter__btn<%= statusFilter === 'canceled'  ? ' orders-filter__btn--active' : '' %>">Canceled</a>
                    </div>
                </div>

                <% if (orders.length === 0) { %>
                    <div class="orders-empty-filter">
                        <p class="orders-empty-filter__text">No orders in this category.</p>
                    </div>
                <% } else { %>
                <ul class="orders">
                    <% orders.forEach(order => {
                        const orderDate = order._id.getTimestamp();
                        const formattedDate = orderDate.toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                        const itemCount = order.products.reduce((s, p) => s + p.quantity, 0);
                        const orderTotal = order.products.reduce((s, p) => s + p.quantity * p.productData.price, 0);
                        const thumbs = order.products.slice(0, 3);
                        const extraCount = order.products.length - 3;
                    %>
                        <li class="order-card">
                            <a href="/orders/<%= order._id %>" class="order-card__link">
                                <div class="order-card__thumbs">
                                    <% thumbs.forEach(p => { %>
                                        <div class="order-card__thumb">
                                            <img src="<%= p.productData.imageUrl %>" alt="<%= p.productData.title %>">
                                        </div>
                                    <% }) %>
                                    <% if (extraCount > 0) { %>
                                        <div class="order-card__thumb order-card__thumb--overflow">+<%= extraCount %></div>
                                    <% } %>
                                </div>
                                <div class="order-card__info">
                                    <div class="order-card__info-top">
                                        <span class="order-card__id">Order #<%= order._id.toString().slice(-8).toUpperCase() %></span>
                                        <span class="order-card__date"><%= formattedDate %></span>
                                    </div>
                                    <div class="order-card__info-bottom">
                                        <span class="order-card__summary"><%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %> &middot; $<%= orderTotal.toFixed(2) %></span>
                                        <span class="order-status-badge order-status-badge--<%= order.status %>"><%= order.status.replace(/_/g, ' ') %></span>
                                    </div>
                                </div>
                                <div class="order-card__chevron">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                    </svg>
                                </div>
                            </a>
                        </li>
                    <% }) %>
                </ul>
                <% } %>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>
