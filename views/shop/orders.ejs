<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/orders.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if (orders.length <= 0) { %>
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="48" height="48">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                        </svg>
                    </div>
                    <h2 class="empty-state__title">No orders yet</h2>
                    <p class="empty-state__subtitle">Your completed orders will appear here.</p>
                    <a href="/" class="btn">Start Shopping</a>
                </div>
            <% } else { %>
                <div class="page-header">
                    <h1 class="page-header__title">Your Orders</h1>
                </div>
                <ul class="orders">
                    <% orders.forEach(order => { %>
                        <li class="order-card">
                            <div class="order-card__header">
                                <div>
                                    <p class="order-card__id">Order #<%= order._id.toString().slice(-8).toUpperCase() %></p>
                                    <p class="order-card__id-full"><%= order._id %></p>
                                </div>
                                <a href="/orders/<%= order._id %>" class="btn" target="_blank" rel="noopener noreferrer">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" style="margin-right:4px;vertical-align:middle;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                    </svg>
                                    Invoice
                                </a>
                            </div>
                            <ul class="order-card__products">
                                <% order.products.forEach(p => { %>
                                    <li class="order-card__product">
                                        <div class="order-card__product-image">
                                            <img src="<%= p.productData.imageUrl %>" alt="<%= p.productData.title %>">
                                        </div>
                                        <div class="order-card__product-info">
                                            <span class="order-card__product-title"><%= p.productData.title %></span>
                                            <span class="order-card__product-price">$<%= p.productData.price.toFixed(2) %> &times; <%= p.quantity %></span>
                                        </div>
                                        <span class="order-card__product-total">$<%= (p.productData.price * p.quantity).toFixed(2) %></span>
                                    </li>
                                <% }) %>
                            </ul>
                            <div class="order-card__footer">
                                <span class="order-card__total">Total: $<%= order.products.reduce((sum, p) => sum + p.quantity * p.productData.price, 0).toFixed(2) %></span>
                            </div>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>
