<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <% const categoryLabels = { electronics: 'Electronics', fashion: 'Fashion', home: 'Home & Living', accessories: 'Accessories' }; %>

    <% if (!locals.activeCategory) { %>
        <section class="hero">
            <div class="hero__content">
                <span class="hero__badge">New arrivals every week</span>
                <h1 class="hero__title">Shop the latest products</h1>
                <p class="hero__subtitle">Discover our curated collection, updated regularly with new arrivals.</p>
                <a href="#products" class="hero__cta">Shop Now →</a>
            </div>
            <div class="hero__wave">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 56" preserveAspectRatio="none">
                    <path fill="#f8fafc" d="M0,28 C360,56 1080,0 1440,28 L1440,56 L0,56 Z"/>
                </svg>
            </div>
        </section>

        <section class="categories">
            <div class="categories__grid">
                <a href="/category/electronics" class="category-card category-card--electronics">
                    <div class="category-card__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />
                        </svg>
                    </div>
                    <h3 class="category-card__title">Electronics</h3>
                    <div class="category-card__corner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                    </div>
                </a>
                <a href="/category/fashion" class="category-card category-card--fashion">
                    <div class="category-card__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
                        </svg>
                    </div>
                    <h3 class="category-card__title">Fashion</h3>
                    <div class="category-card__corner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                    </div>
                </a>
                <a href="/category/home" class="category-card category-card--home">
                    <div class="category-card__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                        </svg>
                    </div>
                    <h3 class="category-card__title">Home & Living</h3>
                    <div class="category-card__corner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                    </div>
                </a>
                <a href="/category/accessories" class="category-card category-card--accessories">
                    <div class="category-card__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.499Z" />
                        </svg>
                    </div>
                    <h3 class="category-card__title">Accessories</h3>
                    <div class="category-card__corner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                    </div>
                </a>
            </div>
        </section>

        <div class="products-section">
            <div class="products-section__header">
                <h2 class="products-section__title">Featured Products</h2>
                <p class="products-section__subtitle">Handpicked items from our collection</p>
            </div>
        </div>
    <% } else { %>
        <div class="category-page-header">
            <a href="/" class="category-page-header__back">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                All Products
            </a>
            <h1 class="category-page-header__title"><%= categoryLabels[activeCategory] || activeCategory %></h1>
        </div>
    <% } %>

    <main id="products">
        <% if (prods.length > 0) { %>
            <div class="grid">
                <% for (let product of prods) { %>
                    <article class="card product-item">
                        <div class="card__image">
                            <img src="<%= product.imageUrl %>" alt="<%= product.title %>" loading="lazy">
                        </div>
                        <div class="card__static">
                            <h3 class="product__title"><%= product.title %></h3>
                            <p class="product__price">$<%= product.price %></p>
                        </div>
                        <div class="card__reveal">
                            <p class="card__reveal-label">Product Details</p>
                            <p class="card__reveal-desc"><%= product.description %></p>
                            <div class="card__actions">
                                <% if (isAuthenticated) { %>
                                    <%- include('../includes/add-to-cart.ejs', {product: product}) %>
                                <% } %>
                                <a href="/products/<%= product._id %>" class="btn card__details-btn">Details</a>
                            </div>
                        </div>
                    </article>
                <% } %>
            </div>
            <%- include('../includes/pagination.ejs', {currentPage: currentPage, nextPage: nextPage, prevPage: prevPage, lastPage: lastPage, hasNextPage: hasNextPage, hasPrevPage: hasPrevPage}) %>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="40" height="40">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
                    </svg>
                </div>
                <% if (locals.activeCategory) { %>
                    <h2 class="empty-state__title">No <%= categoryLabels[activeCategory] %> products yet</h2>
                    <p class="empty-state__subtitle">Nothing here yet — check out our other categories.</p>
                    <a href="/" class="btn empty-state__cta">View all products</a>
                <% } else { %>
                    <h2 class="empty-state__title">No products yet</h2>
                    <p class="empty-state__subtitle">New arrivals are on their way. Browse our categories in the meantime.</p>
                    <a href="#" class="btn empty-state__cta">Browse categories</a>
                <% } %>
            </div>
        <% } %>
    </main>
<%- include('../includes/end.ejs') %>
