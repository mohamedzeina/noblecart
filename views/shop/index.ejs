<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <% const categoryLabels = { electronics: 'Electronics', fashion: 'Fashion', home: 'Home & Living', wearables: 'Wearables & Gadgets' }; %>

    <% if (!locals.activeCategory) { %>
        <section class="hero hero--editorial">
            <div class="hero__grain" aria-hidden="true"></div>
            <div class="hero__inner">
                <div class="hero__eyebrow">
                    <span class="hero__eyebrow-mark">◆</span>
                    <span>New arrivals weekly</span>
                    <span class="hero__eyebrow-sep"></span>
                    <span>Spring 2026</span>
                </div>
                <h1 class="hero__title">
                    <span class="hero__title-line">Shop better</span>
                    <span class="hero__title-line hero__title-line--italic">things<span class="hero__title-dot">.</span></span>
                </h1>
                <div class="hero__footer">
                    <div class="hero__footer-left">
                        <p class="hero__subtitle">Quality electronics, fashion, home goods, and wearables — handpicked and delivered to your door.</p>
                    </div>
                    <div class="hero__footer-right">
                        <a href="#products" class="hero__cta">
                            <span>Shop now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                                <polyline points="12 5 19 12 12 19"/>
                            </svg>
                        </a>
                        <a href="#categories" class="hero__cta-secondary">Shop by category</a>
                    </div>
                </div>
                <div class="hero__corner" aria-hidden="true">
                    <span class="hero__corner-label">Est.</span>
                    <span class="hero__corner-num">2026</span>
                </div>
            </div>
            <div class="hero__marquee" aria-hidden="true">
                <div class="hero__marquee-track">
                    <span class="hero__marquee-item">Free shipping over $100</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item">30-day no-questions returns</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item">New arrivals weekly</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item">Carbon-neutral delivery</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item">Hand-picked by editors</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item">Authenticity guaranteed</span>
                    <span class="hero__marquee-dot">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">Free shipping over $100</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">30-day no-questions returns</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">New arrivals weekly</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">Carbon-neutral delivery</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">Hand-picked by editors</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                    <span class="hero__marquee-item" aria-hidden="true">Authenticity guaranteed</span>
                    <span class="hero__marquee-dot" aria-hidden="true">✦</span>
                </div>
            </div>
        </section>

        <section class="categories categories--editorial" id="categories">
            <div class="categories__header">
                <span class="categories__eyebrow">— Shop by category</span>
                <h2 class="categories__title">Find what you're <em>looking for</em></h2>
            </div>
            <div class="categories__grid">
                <a href="/category/electronics" class="category-card category-card--electronics">
                    <span class="category-card__index">01</span>
                    <div class="category-card__body">
                        <h3 class="category-card__title">Electronics</h3>
                        <span class="category-card__cta">
                            <span>Shop now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </span>
                    </div>
                </a>
                <a href="/category/fashion" class="category-card category-card--fashion">
                    <span class="category-card__index">02</span>
                    <div class="category-card__body">
                        <h3 class="category-card__title">Fashion</h3>
                        <span class="category-card__cta">
                            <span>Shop now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </span>
                    </div>
                </a>
                <a href="/category/home" class="category-card category-card--home">
                    <span class="category-card__index">03</span>
                    <div class="category-card__body">
                        <h3 class="category-card__title">Home &amp; Living</h3>
                        <span class="category-card__cta">
                            <span>Shop now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </span>
                    </div>
                </a>
                <a href="/category/wearables" class="category-card category-card--wearables">
                    <span class="category-card__index">04</span>
                    <div class="category-card__body">
                        <h3 class="category-card__title">Wearables &amp; Gadgets</h3>
                        <span class="category-card__cta">
                            <span>Shop now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </span>
                    </div>
                </a>
            </div>
        </section>

        <div class="products-section products-section--editorial">
            <div class="products-section__header">
                <div class="products-section__lead">
                    <span class="products-section__eyebrow">— All products</span>
                    <h2 class="products-section__title">Everything <em>in store</em></h2>
                </div>
                <p class="products-section__meta">New arrivals every week</p>
            </div>
        </div>
    <% } else { %>
        <div class="category-page-header">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/" class="breadcrumb__item">All Products</a>
                <span class="breadcrumb__sep">/</span>
                <span class="breadcrumb__item breadcrumb__item--current"><%= categoryLabels[activeCategory] || activeCategory %></span>
            </nav>
            <h1 class="category-page-header__title"><%= categoryLabels[activeCategory] || activeCategory %></h1>
        </div>
    <% } %>

    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" class="svg-defs" aria-hidden="true">
        <defs>
            <linearGradient id="hsg" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="50%" stop-color="#f59e0b"/>
                <stop offset="50%" stop-color="#e2e8f0"/>
            </linearGradient>
        </defs>
    </svg>
    <main id="products">
        <% const _priceSuffix = activePrice !== 'all' ? '&price=' + activePrice : ''; %>
        <% const _sortSuffix  = activeSort  !== 'newest' ? '&sort=' + activeSort : ''; %>
        <div class="sort-bar">
            <div class="sort-bar__row">
                <span class="sort-bar__label">Sort by</span>
                <div class="sort-bar__chips">
                    <% [
                        { value: 'newest',     label: 'Newest' },
                        { value: 'price-asc',  label: 'Price: Low to High' },
                        { value: 'price-desc', label: 'Price: High to Low' },
                        { value: 'top-rated',  label: 'Top Rated' },
                    ].forEach(chip => { %>
                    <a href="?sort=<%= chip.value %><%= _priceSuffix %>"
                       class="sort-chip<%= activeSort === chip.value ? ' sort-chip--active' : '' %>"
                       aria-current="<%= activeSort === chip.value ? 'page' : 'false' %>">
                        <%= chip.label %>
                    </a>
                    <% }) %>
                </div>
            </div>
            <div class="sort-bar__row">
                <span class="sort-bar__label">Price</span>
                <div class="sort-bar__chips">
                    <a href="?<%= _sortSuffix ? _sortSuffix.slice(1) : '' %>"
                       class="sort-chip<%= activePrice === 'all' ? ' sort-chip--active' : '' %>"
                       aria-current="<%= activePrice === 'all' ? 'page' : 'false' %>">All</a>
                    <% [
                        { value: '0-50',    label: 'Under $50' },
                        { value: '50-200',  label: '$50 – $200' },
                        { value: '200-500', label: '$200 – $500' },
                        { value: '500up',   label: '$500+' },
                    ].forEach(chip => { %>
                    <a href="?price=<%= chip.value %><%= _sortSuffix %>"
                       class="sort-chip<%= activePrice === chip.value ? ' sort-chip--active' : '' %>"
                       aria-current="<%= activePrice === chip.value ? 'page' : 'false' %>">
                        <%= chip.label %>
                    </a>
                    <% }) %>
                </div>
            </div>
        </div>
        <% if (prods.length > 0) { %>
            <div class="grid">
                <% for (let product of prods) { %>
                    <article class="card product-item" aria-label="<%= product.title %>">
                        <div class="card__image">
                            <img src="<%= product.imageUrl %>" alt="<%= product.title %>" loading="lazy">
                            <%- include('../includes/wishlist-btn.ejs', { product: product }) %>
                            <% if (product.stock === 0) { %>
                                <span class="card__oos-badge">Out of Stock</span>
                            <% } %>
                        </div>
                        <div class="card__static">
                            <% const r = ratingsMap && ratingsMap[product._id.toString()]; %>
                            <% if (r) { %>
                            <% const rFull = r.avg % 1 >= 0.75 ? Math.ceil(r.avg) : Math.floor(r.avg); %>
                            <% const rHalf = r.avg % 1 >= 0.25 && r.avg % 1 < 0.75; %>
                            <div class="card__rating">
                                <div class="card__rating-stars">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <svg class="star<%= i <= rFull ? ' star--filled' : (i === rFull + 1 && rHalf ? ' star--half' : '') %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    <% } %>
                                </div>
                                <span class="card__rating-count"><%= r.avg.toFixed(1) %> (<%= r.count %> review<%= r.count !== 1 ? 's' : '' %>)</span>
                            </div>
                            <% } %>
                            <h3 class="product__title"><%= product.title %></h3>
                            <p class="product__price">$<%= product.price %></p>
                        </div>
                        <div class="card__reveal">
                            <p class="card__reveal-label">Product Details</p>
                            <p class="card__reveal-desc"><%= product.description %></p>
                            <div class="card__actions">
                                <% if (isAuthenticated) { %>
                                    <%- include('../includes/add-to-cart.ejs', {product: product}) %>
                                <% } %>
                                <a href="/products/<%= product._id %>" class="btn card__details-btn">Details</a>
                            </div>
                        </div>
                    </article>
                <% } %>
            </div>
            <%- include('../includes/pagination.ejs', {currentPage, nextPage, prevPage, lastPage, hasNextPage, hasPrevPage, extraQuery}) %>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="40" height="40">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
                    </svg>
                </div>
                <% if (activePrice !== 'all') { %>
                    <h2 class="empty-state__title">No products in that price range</h2>
                    <p class="empty-state__subtitle">Try a different price range or clear the filter.</p>
                    <a href="?<%= activeSort !== 'newest' ? 'sort=' + activeSort : '' %>" class="btn empty-state__cta">Clear price filter</a>
                <% } else if (locals.activeCategory) { %>
                    <h2 class="empty-state__title">No <%= categoryLabels[activeCategory] %> products yet</h2>
                    <p class="empty-state__subtitle">Nothing here yet — check out our other categories.</p>
                    <a href="/" class="btn empty-state__cta">View all products</a>
                <% } else { %>
                    <h2 class="empty-state__title">No products yet</h2>
                    <p class="empty-state__subtitle">New arrivals are on their way. Browse our categories in the meantime.</p>
                    <a href="#" class="btn empty-state__cta">Browse categories</a>
                <% } %>
            </div>
        <% } %>
    </main>
<%- include('../includes/end.ejs') %>
