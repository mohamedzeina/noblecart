<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    <link rel="stylesheet" href="/css/checkout.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <div class="cart-layout">
                <section class="cart-items">
                    <h1 class="cart__title">Review Your Order</h1>
                    <ul class="cart__item-list">
                        <% products.forEach(p => { %>
                            <li class="cart__item">
                                <div class="cart__item-image">
                                    <img src="<%= p.productId.imageUrl %>" alt="<%= p.productId.title %>">
                                </div>
                                <div class="cart__item-info">
                                    <h2 class="cart__item-title"><%= p.productId.title %></h2>
                                    <p class="cart__item-price">$<%= p.productId.price.toFixed(2) %> each &middot; Qty <%= p.quantity %></p>
                                </div>
                                <div class="cart__item-right">
                                    <p class="cart__item-total">$<%= (p.productId.price * p.quantity).toFixed(2) %></p>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </section>
                <aside class="cart-summary">
                    <h2 class="cart-summary__title">Order Summary</h2>
                    <ul class="cart-summary__items">
                        <% products.forEach(p => { %>
                            <li class="cart-summary__item">
                                <span><%= p.productId.title %> &times; <%= p.quantity %></span>
                                <span>$<%= (p.productId.price * p.quantity).toFixed(2) %></span>
                            </li>
                        <% }) %>
                    </ul>
                    <div class="cart-summary__total">
                        <span>Total</span>
                        <span>$<%= totalSum.toFixed(2) %></span>
                    </div>
                    <button id="order-btn" class="btn btn--solid cart-summary__checkout checkout__pay-btn"
                        data-stripe-key="<%= stripePublicKey %>"
                        data-session-id="<%= sessionId %>">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                        </svg>
                        Pay with Stripe
                    </button>
                    <p class="checkout__secure-note">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="12" height="12">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                        </svg>
                        Secured by Stripe · SSL encrypted
                    </p>
                </aside>
            </div>
        </main>
        <script src="https://js.stripe.com/v3/"></script>
        <script src="/js/checkout.js"></script>
        <%- include('../includes/end.ejs') %>
