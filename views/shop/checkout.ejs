<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    <link rel="stylesheet" href="/css/checkout.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <div class="cart-layout">
                <section class="cart-items">
                    <h1 class="cart__title">Review Your Order</h1>
                    <ul class="cart__item-list">
                        <% products.forEach(p => { %>
                            <li class="cart__item" data-product-id="<%= p.productId._id %>" data-price="<%= p.productId.price %>" data-stock="<%= p.productId.stock %>">
                                <div class="cart__item-image">
                                    <img src="<%= p.productId.imageUrl %>" alt="<%= p.productId.title %>">
                                </div>
                                <div class="cart__item-info">
                                    <h2 class="cart__item-title"><%= p.productId.title %></h2>
                                    <p class="cart__item-price">$<%= p.productId.price.toFixed(2) %> each</p>
                                    <div class="cart__qty-controls">
                                        <button type="button" class="cart__qty-btn checkout-qty-dec" aria-label="Decrease quantity">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="12" height="12"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"/></svg>
                                        </button>
                                        <span class="cart__qty-value"><%= p.quantity %></span>
                                        <button type="button" class="cart__qty-btn checkout-qty-inc" aria-label="Increase quantity">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="12" height="12"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="cart__item-right">
                                    <p class="cart__item-total js-item-total">$<%= (p.productId.price * p.quantity).toFixed(2) %></p>
                                    <button type="button" class="cart__delete-btn checkout-remove" aria-label="Remove item">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
                                    </button>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </section>
                <aside class="cart-summary <%= locals.stockError ? 'cart-summary--stock-error' : '' %>">
                    <h2 class="cart-summary__title">Order Summary</h2>
                    <ul class="cart-summary__items">
                        <% products.forEach(p => { %>
                            <li class="cart-summary__item" data-product-id="<%= p.productId._id %>">
                                <span><%= p.productId.title %> &times; <span class="js-summary-qty"><%= p.quantity %></span></span>
                                <span class="js-summary-total">$<%= (p.productId.price * p.quantity).toFixed(2) %></span>
                            </li>
                        <% }) %>
                    </ul>
                    <div class="cart-summary__total">
                        <span>Total</span>
                        <span class="js-grand-total">$<%= totalSum.toFixed(2) %></span>
                    </div>
                    <div id="checkout-stock-error" class="checkout__stock-error">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="16" height="16">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                        </svg>
                        <span id="checkout-stock-error-msg"><%= locals.stockError || '' %></span>
                    </div>
                    <button id="order-btn" class="btn btn--solid cart-summary__checkout checkout__pay-btn"
                        data-stripe-key="<%= stripePublicKey %>"
                        data-session-id="<%= sessionId || '' %>">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                        </svg>
                        Pay with Stripe
                    </button>
                    <p class="checkout__secure-note">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="12" height="12">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                        </svg>
                        Secured by Stripe · SSL encrypted
                    </p>
                </aside>
            </div>
        </main>
        <script src="https://js.stripe.com/v3/"></script>
        <script src="/js/checkout.js"></script>
        <script src="/js/checkout-qty.js"></script>
        <%- include('../includes/end.ejs') %>
