<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/admin.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>

        <main>
            <div class="admin-page-header">
                <div class="admin-page-header__left">
                    <h1 class="admin-page-header__title">All Orders</h1>
                    <p class="admin-page-header__subtitle"><%= orders.length %> order<%= orders.length !== 1 ? 's' : '' %> on this page</p>
                </div>
            </div>

            <div class="admin-filters">
                <div class="admin-filters__group">
                    <span class="admin-filters__label">Status</span>
                    <div class="admin-filters__chips">
                        <% const statusChips = [
                            { value: '', label: 'All' },
                            { value: 'pending', label: 'Pending' },
                            { value: 'confirmed', label: 'Confirmed' },
                            { value: 'shipped', label: 'Shipped' },
                            { value: 'out_for_delivery', label: 'Out for delivery' },
                            { value: 'delivered', label: 'Delivered' },
                            { value: 'canceled', label: 'Canceled' },
                        ]; %>
                        <% statusChips.forEach(chip => { %>
                        <a href="/admin/orders?status=<%= chip.value %>&date=<%= activeDate %>"
                           class="admin-filter-chip<%= activeStatus === chip.value ? ' admin-filter-chip--active' : '' %>">
                            <%= chip.label %>
                        </a>
                        <% }) %>
                    </div>
                </div>
                <div class="admin-filters__group">
                    <span class="admin-filters__label">Date</span>
                    <div class="admin-filters__chips">
                        <% const dateChips = [
                            { value: '', label: 'All time' },
                            { value: 'today', label: 'Today' },
                            { value: '7d', label: 'Last 7 days' },
                            { value: '30d', label: 'Last 30 days' },
                        ]; %>
                        <% dateChips.forEach(chip => { %>
                        <a href="/admin/orders?status=<%= activeStatus %>&date=<%= chip.value %>"
                           class="admin-filter-chip<%= activeDate === chip.value ? ' admin-filter-chip--active' : '' %>">
                            <%= chip.label %>
                        </a>
                        <% }) %>
                    </div>
                </div>
            </div>

            <%
                const VALID_TRANSITIONS = {
                    pending:          ['confirmed', 'canceled'],
                    confirmed:        ['shipped', 'canceled'],
                    shipped:          ['out_for_delivery'],
                    out_for_delivery: ['delivered'],
                    delivered:        [],
                    canceled:         [],
                };
                const STATUS_LABELS = {
                    confirmed:        'Confirmed',
                    shipped:          'Shipped',
                    out_for_delivery: 'Out for delivery',
                    delivered:        'Delivered',
                    canceled:         'Canceled',
                };
            %>
            <% if (orders.length > 0) { %>
                <div class="admin-order-list">
                    <% orders.forEach(order => { %>
                        <%
                            const total = order.products.reduce((sum, p) => sum + p.quantity * p.productData.price, 0);
                            const shortId = '#' + order._id.toString().slice(-8).toUpperCase();
                            const itemCount = order.products.reduce((sum, p) => sum + p.quantity, 0);
                            const nextStatuses = VALID_TRANSITIONS[order.status] || [];
                            const placedEntry = order.statusHistory.find(h => h.status === 'pending');
                            let placedDate = '—';
                            if (placedEntry) {
                                const diff = Date.now() - new Date(placedEntry.timestamp).getTime();
                                const mins  = Math.floor(diff / 60000);
                                const hours = Math.floor(diff / 3600000);
                                const days  = Math.floor(diff / 86400000);
                                if (mins < 1)        placedDate = 'Just now';
                                else if (mins < 60)  placedDate = `${mins}m ago`;
                                else if (hours < 24) placedDate = `${hours}h ago`;
                                else if (days < 7)   placedDate = `${days}d ago`;
                                else                 placedDate = new Date(placedEntry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                            }
                        %>
                        <article class="admin-order-item">
                            <div class="admin-order-item__info">
                                <p class="admin-order-item__id"><%= shortId %></p>
                                <p class="admin-order-item__email"><%= order.user.email %></p>
                                <p class="admin-order-item__date"><%= placedDate %></p>
                            </div>
                            <div class="admin-order-item__meta">
                                <span class="admin-order-item__items"><%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %></span>
                                <span class="admin-order-item__total">$<%= total.toFixed(2) %></span>
                            </div>
                            <div class="admin-order-item__status">
                                <span class="order-status-badge order-status-badge--<%= order.status %>"><%= order.status.replace(/_/g, ' ') %></span>
                                <% if (nextStatuses.length > 0) { %>
                                <div class="order-status-actions">
                                    <span class="order-status-actions__label">Move to:</span>
                                    <% nextStatuses.forEach(s => { %>
                                    <button class="order-status-btn<%= s === 'canceled' ? ' order-status-btn--danger' : '' %>"
                                            type="button"
                                            data-order-id="<%= order._id %>"
                                            data-csrf="<%= csrfToken %>"
                                            data-status="<%= s %>">
                                        <%= STATUS_LABELS[s] %>
                                    </button>
                                    <% }) %>
                                </div>
                                <% } %>
                            </div>
                        </article>
                    <% }) %>
                </div>
                <%- include('../includes/pagination.ejs', {currentPage, nextPage, prevPage, lastPage, hasNextPage, hasPrevPage}) %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="48" height="48">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                        </svg>
                    </div>
                    <h2 class="empty-state__title"><%= (activeStatus || activeDate) ? 'No matching orders' : 'No orders yet' %></h2>
                    <p class="empty-state__subtitle"><%= (activeStatus || activeDate) ? 'Try adjusting your filters.' : 'Orders placed by customers will appear here.' %></p>
                </div>
            <% } %>
        </main>
        <script src="/js/admin.js"></script>
        <%- include('../includes/end.ejs') %>
