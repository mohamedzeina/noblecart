<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>

<body class="admin-body">
   <%- include('../includes/admin-sidebar.ejs') %>

    <main class="admin-main">
        <div class="admin-page admin-page--form">
        <a href="/admin/products" class="apd-back">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
            My Products
        </a>
        <div class="admin-page-header">
            <div class="admin-page-header__left">
                <span class="admin-page-header__eyebrow"><% if (editing) { %>— Editing<% } else { %>— New product<% } %></span>
                <h1 class="admin-page-header__title"><% if (editing) { %>Edit <em>product</em><% } else { %>Add a <em>product</em><% } %></h1>
                <p class="admin-page-header__subtitle"><% if (editing) { %>Update product details, stock, and category.<% } else { %>Upload a 3D model or image and fill in the basics.<% } %></p>
            </div>
        </div>
        <div class="admin-form-card">
            <% if (errorMessage) { %>
                <p class="admin-form-card__error"><%= errorMessage %></p>
            <% } %>
            <form action="/admin/<% if (editing) { %>edit-product<% } else { %>add-product<% } %>" method="POST" enctype="multipart/form-data">
                <div class="form-control">
                    <label for="title">Title</label>
                    <input
                    class="<%= validationErrors.find(e => e.path === 'title') ? 'invalid' : '' %>"
                    type="text"
                    name="title"
                    id="title"
                    value="<% if (editing || hasError) { %><%= product.title %><% } %>">
                </div>
                <div class="form-control">
                    <label>3D Model <span class="form-control__hint">(optional — .glb)</span></label>
                    <div class="file-upload" id="model-upload-area">
                        <input type="file" name="model" id="model-file" accept=".glb" class="file-upload__input">
                        <% if (editing && product.modelUrl) { %>
                            <div class="file-upload__placeholder" id="model-placeholder">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                                </svg>
                                <p>Current model loaded — click to replace</p>
                                <span>.glb</span>
                            </div>
                        <% } else { %>
                            <div class="file-upload__placeholder" id="model-placeholder">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                                </svg>
                                <p>Click to upload .glb</p>
                                <span>3D model file — auto-generates product image</span>
                            </div>
                        <% } %>
                    </div>
                    <div id="model-viewer-container"></div>
                </div>
                <div class="form-control">
                    <label>Product Image <span class="form-control__hint" id="image-label-hint">(auto-filled from 3D model, or upload manually)</span></label>
                    <div class="file-upload" id="file-upload-area">
                        <input type="file" name="image" id="image" accept="image/png,image/jpeg,image/jpg" class="file-upload__input">
                        <% if (editing && product.imageUrl) { %>
                            <img src="<%= product.imageUrl %>" alt="Current image" class="file-upload__preview" id="image-preview">
                            <p class="file-upload__hint">Click or drag to replace</p>
                        <% } else { %>
                            <img src="" alt="" class="file-upload__preview hidden" id="image-preview">
                            <div class="file-upload__placeholder" id="upload-placeholder">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                                </svg>
                                <p>Click to upload or drag and drop</p>
                                <span>PNG or JPG</span>
                            </div>
                        <% } %>
                    </div>
                </div>
                <div class="form-control">
                    <label for="price">Price ($)</label>
                    <input
                    class="<%= validationErrors.find(e => e.path === 'price') ? 'invalid' : '' %>"
                    type="number"
                    name="price"
                    id="price"
                    step="0.01"
                    value="<% if (editing || hasError) { %><%= product.price %><% } %>">
                </div>
                <div class="form-control">
                    <label for="stock">Stock Quantity</label>
                    <input
                    type="number"
                    name="stock"
                    id="stock"
                    min="0"
                    step="1"
                    value="<% if (editing || hasError) { %><%= product.stock || 0 %><% } else { %>0<% } %>">
                </div>
                <div class="form-control">
                    <label for="category">Category</label>
                    <select name="category" id="category" class="<%= validationErrors.find(e => e.path === 'category') ? 'invalid' : '' %>">
                        <option value="" disabled <%= (editing || hasError) && product.category ? '' : 'selected' %>>Select a category</option>
                        <% [
                            { value: 'electronics', label: 'Electronics' },
                            { value: 'fashion',     label: 'Fashion' },
                            { value: 'home',        label: 'Home & Living' },
                            { value: 'wearables',   label: 'Wearables & Gadgets' },
                        ].forEach(({ value: cat, label }) => { %>
                            <option value="<%= cat %>" <%= (editing || hasError) && product.category === cat ? 'selected' : '' %>><%= label %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-control">
                    <label for="description">Description</label>
                    <textarea
                    class="<%= validationErrors.find(e => e.path === 'description') ? 'invalid' : '' %>"
                    name="description"
                    id="description"
                    rows="4"><% if (editing || hasError) { %><%= product.description %><% } %></textarea>
                </div>
                <% if (editing) { %>
                    <input type="hidden" value="<%= product._id %>" name="productId">
                <% } %>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="admin-form-card__actions">
                    <a href="/admin/products" class="admin-btn admin-btn--ghost">Cancel</a>
                    <button class="admin-btn admin-btn--primary" type="submit"><% if (editing) { %>Update product<% } else { %>Add product<% } %></button>
                </div>
            </form>
        </div>
        </div>
    </main>
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
<script src="/js/upload.js"></script>
<%- include('../includes/end.ejs') %>
