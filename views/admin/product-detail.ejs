<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/admin.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>

        <main>
            <%
                const catLabels = { electronics: 'Electronics', fashion: 'Fashion', home: 'Home & Living', wearables: 'Wearables & Gadgets' };
            %>

            <div class="admin-page-header">
                <div class="admin-page-header__left">
                    <a href="/admin/products" class="apd-back">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
                        My Products
                    </a>
                    <h1 class="admin-page-header__title"><%= product.title %></h1>
                </div>
                <div class="apd-header-actions card__actions">
                    <a href="/admin/edit-product/<%= product._id %>?edit=true" class="btn btn--solid">Edit</a>
                    <input type="hidden" value="<%= product._id %>" name="productId">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn delete-btn" type="button">Delete</button>
                </div>
            </div>

            <div class="apd-layout">

                <!-- Left column: image + meta -->
                <div class="apd-left">
                    <div class="apd-image">
                        <img src="<%= product.imageUrl %>" alt="<%= product.title %>">
                        <% if (product.modelUrl) { %>
                            <span class="admin-product-item__badge--3d">3D</span>
                        <% } %>
                    </div>
                    <div class="apd-meta">
                        <div class="apd-meta__row">
                            <span class="apd-meta__label">Price</span>
                            <span class="apd-meta__value">$<%= product.price.toFixed(2) %></span>
                        </div>
                        <div class="apd-meta__row">
                            <span class="apd-meta__label">Category</span>
                            <span class="apd-meta__value"><%= catLabels[product.category] || product.category %></span>
                        </div>
                        <div class="apd-meta__row apd-meta__row--desc">
                            <span class="apd-meta__label">Description</span>
                            <span class="apd-meta__value apd-meta__value--desc"><%= product.description %></span>
                        </div>
                    </div>
                </div>

                <!-- Right column: KPIs + stock + reviews -->
                <div class="apd-right">

                    <!-- KPI cards -->
                    <div class="apd-kpis">
                        <div class="apd-kpi">
                            <span class="apd-kpi__value <%= product.stock === 0 ? 'apd-kpi__value--danger' : product.stock <= 5 ? 'apd-kpi__value--warn' : '' %>"><%= product.stock %></span>
                            <span class="apd-kpi__label">In Stock</span>
                        </div>
                        <div class="apd-kpi">
                            <span class="apd-kpi__value"><%= unitsSold %></span>
                            <span class="apd-kpi__label">Units Sold</span>
                        </div>
                        <div class="apd-kpi">
                            <span class="apd-kpi__value"><%= rating.count %></span>
                            <span class="apd-kpi__label">Reviews</span>
                        </div>
                        <div class="apd-kpi">
                            <span class="apd-kpi__value"><%= rating.count > 0 ? rating.avg.toFixed(1) : '—' %></span>
                            <span class="apd-kpi__label">Avg Rating</span>
                        </div>
                    </div>

                    <!-- Stock update -->
                    <div class="apd-stock-card">
                        <h2 class="apd-stock-card__title">Update Stock</h2>
                        <form id="stock-form" action="/admin/update-stock" method="POST" class="apd-stock-form">
                            <input type="hidden" name="productId" value="<%= product._id %>">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="apd-stock-form__controls">
                                <button type="button" class="apd-stock-btn" id="stock-dec">−</button>
                                <input type="number" name="stock" id="stock-input" class="apd-stock-input" value="<%= product.stock %>" min="0" step="1">
                                <button type="button" class="apd-stock-btn" id="stock-inc">+</button>
                            </div>
                            <button id="stock-save" type="submit" class="btn btn--solid apd-stock-save">Save</button>
                        </form>
                    </div>

                    <!-- Reviews -->
                    <div class="apd-reviews">
                        <h2 class="apd-reviews__title">Reviews <span class="apd-reviews__count"><%= rating.count %></span></h2>
                        <% if (reviews.length === 0) { %>
                            <p class="apd-reviews__empty">No reviews yet.</p>
                        <% } else { %>
                            <div class="apd-review-list">
                                <% for (const review of reviews) { %>
                                    <div class="apd-review">
                                        <div class="apd-review__header">
                                            <div class="apd-review__stars">
                                                <% for (let i = 1; i <= 5; i++) { %>
                                                    <svg class="star <%= i <= review.rating ? 'star--filled' : '' %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                                <% } %>
                                            </div>
                                            <span class="apd-review__user"><%= review.userName %></span>
                                            <% if (review.verifiedPurchase) { %>
                                                <span class="apd-review__verified">Verified</span>
                                            <% } %>
                                            <span class="apd-review__date"><%= review.createdAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                        </div>
                                        <p class="apd-review__comment"><%= review.comment %></p>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>

                </div>
            </div>
        </main>

        <script src="/js/admin.js"></script>
        <%- include('../includes/end.ejs') %>
