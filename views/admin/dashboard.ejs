<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/admin.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>

        <main class="dash-main">
            <div class="admin-page-header dash-header">
                <div class="admin-page-header__left">
                    <h1 class="admin-page-header__title">Dashboard</h1>
                    <p class="admin-page-header__subtitle">Overview of your store performance</p>
                </div>
                <div class="dash-period-filter">
                    <a href="/admin/dashboard?period=7d"  class="dash-period-btn<%= period === '7d'  ? ' dash-period-btn--active' : '' %>">7D</a>
                    <a href="/admin/dashboard?period=30d" class="dash-period-btn<%= period === '30d' ? ' dash-period-btn--active' : '' %>">30D</a>
                    <a href="/admin/dashboard?period=all" class="dash-period-btn<%= period === 'all' ? ' dash-period-btn--active' : '' %>">All</a>
                </div>
            </div>

            <!-- KPI row -->
            <div class="dash-kpis">
                <div class="dash-kpi dash-kpi--green">
                    <div class="dash-kpi__icon dash-kpi__icon--green">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    </div>
                    <div class="dash-kpi__body">
                        <span class="dash-kpi__label">Total Revenue</span>
                        <span class="dash-kpi__value" data-target="<%= totalRevenue %>" data-prefix="$" data-decimals="2">$0.00</span>
                    </div>
                </div>
                <div class="dash-kpi dash-kpi--blue">
                    <div class="dash-kpi__icon dash-kpi__icon--blue">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
                    </div>
                    <div class="dash-kpi__body">
                        <span class="dash-kpi__label">Paid Orders</span>
                        <span class="dash-kpi__value" data-target="<%= paidOrders %>" data-prefix="" data-decimals="0">0</span>
                    </div>
                </div>
                <div class="dash-kpi dash-kpi--amber">
                    <div class="dash-kpi__icon dash-kpi__icon--amber">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
                    </div>
                    <div class="dash-kpi__body">
                        <span class="dash-kpi__label">Avg Order Value</span>
                        <span class="dash-kpi__value" data-target="<%= avgOrderValue %>" data-prefix="$" data-decimals="2">$0.00</span>
                    </div>
                </div>
                <div class="dash-kpi dash-kpi--purple">
                    <div class="dash-kpi__icon dash-kpi__icon--purple">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" /></svg>
                    </div>
                    <div class="dash-kpi__body">
                        <span class="dash-kpi__label">Products Listed</span>
                        <span class="dash-kpi__value" data-target="<%= productCount %>" data-prefix="" data-decimals="0">0</span>
                    </div>
                </div>
            </div>

            <!-- Revenue trend chart -->
            <div class="dash-card dash-card--full dash-chart-card">
                <h2 class="dash-card__title">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="15" height="15"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" /></svg>
                    Revenue Trend
                </h2>
                <div class="dash-chart-wrap">
                    <canvas id="revenue-chart"
                        data-labels="<%= dailyRevenue.map(d => d.date).join(',') %>"
                        data-values="<%= dailyRevenue.map(d => d.revenue.toFixed(2)).join(',') %>">
                    </canvas>
                </div>
            </div>

            <!-- Middle row -->
            <div class="dash-mid">

                <!-- Top products -->
                <div class="dash-card">
                    <h2 class="dash-card__title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="15" height="15"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
                        Top Products
                    </h2>
                    <% if (topProducts.length === 0) { %>
                        <p class="dash-empty">No sales data yet.</p>
                    <% } else { %>
                        <div class="dash-table-wrap">
                        <table class="dash-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Product</th>
                                    <th class="dash-table__num">Units</th>
                                    <th class="dash-table__num">Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% topProducts.forEach((p, i) => { %>
                                    <tr>
                                        <td class="dash-table__rank">
                                            <span class="dash-rank dash-rank--<%= i + 1 %>"><%= i + 1 %></span>
                                        </td>
                                        <td class="dash-table__name"><%= p._id %></td>
                                        <td class="dash-table__num"><%= p.unitsSold %></td>
                                        <td class="dash-table__num dash-table__revenue">$<%= p.revenue.toFixed(2) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                        </div>
                    <% } %>
                </div>

                <!-- Order status breakdown -->
                <div class="dash-card">
                    <h2 class="dash-card__title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="15" height="15"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" /></svg>
                        Orders by Status
                    </h2>
                    <% if (statusBreakdown.length === 0) { %>
                        <p class="dash-empty">No orders yet.</p>
                    <% } else { %>
                        <%
                            const totalForBreakdown = statusBreakdown.reduce((s, r) => s + r.count, 0);
                        %>
                        <div class="dash-status-list">
                            <% statusBreakdown.forEach(row => { %>
                                <%
                                    const pct = Math.round((row.count / totalForBreakdown) * 100);
                                    const label = row._id.replace(/_/g, ' ');
                                %>
                                <div class="dash-status-row">
                                    <div class="dash-status-row__top">
                                        <span class="dash-status-row__dot dash-status-row__dot--<%= row._id %>"></span>
                                        <span class="dash-status-row__label"><%= label %></span>
                                        <span class="dash-status-row__count"><%= row.count %></span>
                                    </div>
                                    <div class="dash-status-row__bar-bg" data-tooltip="<%= pct %>%">
                                        <div class="dash-status-row__bar dash-status-row__bar--<%= row._id %>" data-pct="<%= pct %>"></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Recent orders -->
            <div class="dash-card dash-card--full">
                <h2 class="dash-card__title">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="15" height="15"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    Recent Orders
                </h2>
                <% if (recentOrders.length === 0) { %>
                    <p class="dash-empty">No orders yet.</p>
                <% } else { %>
                    <div class="dash-table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="dash-table__num">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentOrders.forEach(o => { %>
                                <tr class="dash-table__row--link" onclick="window.location='/admin/orders'">
                                    <td class="dash-table__id">#<%= o.id %></td>
                                    <td class="dash-table__email"><%= o.email %></td>
                                    <td class="dash-table__date"><%= o.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                    <td><span class="order-status-badge order-status-badge--<%= o.status %>"><%= o.status.replace(/_/g, ' ') %></span></td>
                                    <td class="dash-table__num dash-table__revenue">$<%= o.total.toFixed(2) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    </div>
                    <a href="/admin/orders" class="dash-all-link">View all orders →</a>
                <% } %>
            </div>

        </main>
        <script src="/js/admin.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script src="/js/dashboard.js"></script>
        <%- include('../includes/end.ejs') %>
