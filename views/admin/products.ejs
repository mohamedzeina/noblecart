<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/admin.css">
    </head>

    <body class="admin-body">
        <%- include('../includes/admin-sidebar.ejs') %>

        <main class="admin-main">
            <div class="admin-page">
            <div class="admin-page-header">
                <div class="admin-page-header__left">
                    <span class="admin-page-header__eyebrow">— Catalog</span>
                    <h1 class="admin-page-header__title">My <em>products</em></h1>
                    <p class="admin-page-header__subtitle"><%= prods.length %> product<%= prods.length !== 1 ? 's' : '' %> on this page</p>
                </div>
                <a href="/admin/add-product" class="admin-btn admin-btn--primary">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Add product
                </a>
            </div>

            <%
                const catLabels = { electronics: 'Electronics', fashion: 'Fashion', home: 'Home & Living', wearables: 'Wearables & Gadgets' };
                const categoryChips = [
                    { value: '', label: 'All' },
                    { value: 'electronics', label: 'Electronics' },
                    { value: 'fashion', label: 'Fashion' },
                    { value: 'home', label: 'Home & Living' },
                    { value: 'wearables', label: 'Wearables & Gadgets' },
                ];
            %>
            <div class="admin-filters">
                <div class="admin-filters__group">
                    <span class="admin-filters__label">Category</span>
                    <div class="admin-filters__chips">
                        <% categoryChips.forEach(chip => { %>
                        <a href="/admin/products?category=<%= chip.value %>"
                           class="admin-filter-chip<%= activeCategory === chip.value ? ' admin-filter-chip--active' : '' %>">
                            <%= chip.label %>
                        </a>
                        <% }) %>
                    </div>
                </div>
            </div>

            <% if (prods.length > 0) { %>
                <div class="admin-product-list">
                    <% for (let product of prods) { %>
                        <article class="admin-product-item">
                            <a href="/admin/product/<%= product._id %>" class="admin-product-item__link" aria-label="View <%= product.title %> details">
                            <div class="admin-product-item__thumb">
                                <img src="<%= product.imageUrl %>" alt="<%= product.title %>" loading="lazy">
                            </div>
                            <div class="admin-product-item__info">
                                <h2 class="admin-product-item__title"><%= product.title %></h2>
                                <div class="admin-product-item__meta">
                                    <span class="admin-product-item__price">$<%= product.price.toFixed(2) %></span>
                                    <% if (product.category) { %>
                                        <span class="admin-product-item__category"><%= catLabels[product.category] || product.category %></span>
                                    <% } %>
                                    <% if (product.modelUrl) { %>
                                        <span class="admin-product-item__badge--3d">3D</span>
                                    <% } %>
                                    <% const ar = ratingsMap && ratingsMap[product._id.toString()]; %>
                                    <% if (ar) { %>
                                        <span class="admin-product-item__rating">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="10" height="10" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                            <%= ar.avg.toFixed(1) %> <span class="admin-product-item__rating-count">(<%= ar.count %>)</span>
                                        </span>
                                    <% } %>
                                </div>
                                <p class="admin-product-item__desc"><%= product.description %></p>
                            </div>
                            </a>
                            <div class="card__actions admin-product-item__actions">
                                <a href="/admin/edit-product/<%= product._id %>?edit=true" class="admin-btn admin-btn--primary">Edit</a>
                                <input type="hidden" value="<%= product._id %>" name="productId">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <button class="admin-btn admin-btn--ghost delete-btn" type="button">Delete</button>
                            </div>
                        </article>
                    <% } %>
                </div>
                <%- include('../includes/pagination.ejs', {currentPage, nextPage, prevPage, lastPage, hasNextPage, hasPrevPage, extraQuery}) %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="48" height="48">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </div>
                    <h2 class="empty-state__title"><%= activeCategory ? 'No products in this category' : 'No products yet' %></h2>
                    <p class="empty-state__subtitle"><%= activeCategory ? 'Try a different category or add a new product.' : 'Get started by adding your first product.' %></p>
                    <a href="/admin/add-product" class="btn empty-state__cta">Add product</a>
                </div>
            <% } %>
            </div>
        </main>
        <%- include('../includes/end.ejs') %>
        <script src="/js/admin.js"></script>
