<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body>

    <main>
        <div class="auth-card">
            <a class="auth-card__brand" href="/">
                <span class="auth-card__brand-mark" aria-hidden="true">◆</span>
                <span>Noble<span class="auth-card__brand-italic">cart</span></span>
            </a>
            <div class="auth-card__eyebrow">Sign in</div>
            <h1 class="auth-card__title">Welcome <em>back</em><span class="auth-card__title-dot">.</span></h1>
            <p class="auth-card__subtitle">Sign in to access your orders, wishlist, and saved addresses.</p>
            <% if (errorMessage) { %>
            <p class="auth-card__error" role="alert"><%= errorMessage %></p>
            <% } %>
            <form action="/login" method="POST" novalidate>
                <div class="form-control">
                    <label for="email">E-Mail</label>
                    <input
                    class="<%= validationErrors.find(e => e.path === 'email') ? 'invalid' : '' %>"
                    type="email"
                    name="email"
                    id="email"
                    value="<%= oldInput.email %>"
                    placeholder="you@example.com">
                </div>
                <div class="form-control">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <input
                        class="<%= validationErrors.find(e => e.path === 'password') ? 'invalid' : '' %>"
                        type="password"
                        name="password"
                        id="password"
                        value="<%= oldInput.password %>"
                        placeholder="Your password">
                        <button type="button" class="input-toggle" aria-label="Show password">
                            <svg class="eye-show" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="eye-hide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        </button>
                    </div>
                </div>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn" type="submit">Login</button>
            </form>
            <div class="auth-card__footer">
                <a href="/signup">Create an account</a>
                <a href="/reset">Forgot your password?</a>
            </div>
        </div>
    </main>
<script src="/js/auth.js"></script>
<%- include('../includes/end.ejs') %>
