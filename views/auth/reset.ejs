<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body>
   <%- include('../includes/navigation.ejs') %>

    <main>
        <div class="auth-card">
            <div class="auth-card__logo">
                <div class="auth-card__logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="22" height="22">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                    </svg>
                </div>
            </div>
            <% if (successMessage) { %>
                <div class="auth-card__success">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="40" height="40">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <h1 class="auth-card__title">Check your inbox</h1>
                    <p class="auth-card__subtitle">A reset link is on its way to your email.</p>
                </div>
            <% } else { %>
                <h1 class="auth-card__title">Reset password</h1>
                <p class="auth-card__subtitle">Enter your email and we'll send you a reset link</p>
                <% if (errorMessage) { %>
                <p class="auth-card__error"><%= errorMessage %></p>
                <% } %>
                <form action="/reset" method="POST">
                    <div class="form-control">
                        <label for="email">E-Mail</label>
                        <input type="email" name="email" id="email" placeholder="you@example.com">
                    </div>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn" type="submit">Send Reset Link</button>
                </form>
            <% } %>
            <div class="auth-card__footer">
                <a href="/login">Back to login</a>
            </div>
        </div>
    </main>
<%- include('../includes/end.ejs') %>
