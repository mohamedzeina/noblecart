<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/signup-avatar.css">
</head>

<body>

    <main>
        <div class="auth-card">
            <div class="auth-card__logo">
                <div class="auth-card__logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="22" height="22">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                    </svg>
                </div>
            </div>
            <h1 class="auth-card__title">Create an account</h1>
            <p class="auth-card__subtitle">Start shopping today</p>
            <% if (errorMessage) { %>
            <p class="auth-card__error" role="alert"><%= errorMessage %></p>
            <% } %>
            <form action="/signup" method="POST" enctype="multipart/form-data" novalidate>
                <div class="signup-avatar">
                    <label for="avatar" class="signup-avatar__label" aria-label="Upload profile photo (optional)">
                        <div class="signup-avatar__circle" id="avatar-preview-wrap">
                            <span class="signup-avatar__initial" id="avatar-initial">?</span>
                            <img class="signup-avatar__img hidden" id="avatar-img-preview" src="" alt="Avatar preview" />
                            <div class="signup-avatar__overlay">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" /></svg>
                            </div>
                        </div>
                        <span class="signup-avatar__hint">Photo (optional)</span>
                    </label>
                    <input type="file" name="avatar" id="avatar" accept="image/*" class="signup-avatar__input" />
                </div>
                <div class="form-control">
                    <label for="name">Full Name</label>
                    <input
                    class="<%= validationErrors.find(e => e.path === 'name') ? 'invalid' : '' %>"
                    type="text"
                    name="name"
                    id="name"
                    value="<%= oldInput.name %>"
                    placeholder="Your name"
                    autocomplete="name">
                </div>
                <div class="form-control">
                    <label for="email">E-Mail</label>
                    <input
                    class="<%= validationErrors.find(e => e.path === 'email') ? 'invalid' : '' %>"
                    type="email"
                    name="email"
                    id="email"
                    value="<%= oldInput.email %>"
                    placeholder="you@example.com">
                </div>
                <div class="form-control">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <input
                        class="<%= validationErrors.find(e => e.path === 'password') ? 'invalid' : '' %>"
                        type="password"
                        name="password"
                        id="password"
                        value="<%= oldInput.password %>"
                        placeholder="At least 6 characters">
                        <button type="button" class="input-toggle" aria-label="Show password">
                            <svg class="eye-show" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="eye-hide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        </button>
                    </div>
                </div>
                <div class="form-control">
                    <label for="confirmPassword">Confirm Password</label>
                    <div class="input-wrapper">
                        <input
                        class="<%= validationErrors.find(e => e.path === 'confirmPassword') ? 'invalid' : '' %>"
                        type="password"
                        name="confirmPassword"
                        id="confirmPassword"
                        value="<%= oldInput.confirmPassword %>"
                        placeholder="Repeat your password">
                        <button type="button" class="input-toggle" aria-label="Show password">
                            <svg class="eye-show" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="eye-hide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        </button>
                    </div>
                </div>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn" type="submit">Sign Up</button>
            </form>
            <div class="auth-card__footer">
                Already have an account? <a href="/login">Log in</a>
            </div>
        </div>
    </main>
<script src="/js/auth.js"></script>
<script src="/js/signup-avatar.js"></script>
<%- include('../includes/end.ejs') %>
